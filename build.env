# Build-time arguments baked into the frontend bundle.
# These are hardcoded into the compiled image — changing them requires a rebuild.

VITE_RELAY_API_BASE_URL=https://vk-relay.gabrielbelli.com

# Optional observability (leave empty to disable)
SENTRY_DSN_REMOTE=
POSTHOG_API_KEY=
POSTHOG_API_ENDPOINT=

# Upstream vibekanban ref to build (tag, branch, or commit SHA).
# Set to a specific tag to avoid building sunset versions.
# Leave empty or set to "main" to track latest upstream (includes sunset).
VIBEKANBAN_REF=v0.1.43-20260417125614
